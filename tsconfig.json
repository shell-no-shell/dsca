{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "declaration": true,
    "sourceMap": true,
    "resolveJsonModule": true,
    "paths": {
      "@dsca/tools": ["./packages/tools/src/index.ts"],
      "@dsca/core": ["./packages/core/src/index.ts"],
      "@dsca/sdk": ["./packages/sdk/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "dist", "packages/**/dist"]
}
